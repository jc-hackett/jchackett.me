{# ===== Component: Disclosure Group ===== #}

{% set showHeader = showComponentTitle != false %}
<section class="disclosure-group{% if not showHeader %} disclosure-group-plain{% endif %}" aria-label="{{ ariaLabel or title }}">
  {% if showHeader %}
  <details>
    <summary class="disclosure-header">{{ title }}</summary>
  {% endif %}

    {% for item in items %}
      <details class="disclosure-item">
        <summary>{{ item.title }}</summary>

        <div class="content-block">
          {{ item.content | safe }}
        </div>
      </details>
    {% endfor %}
  {% if showHeader %}
  </details>
  {% endif %}
</section>

{# ===== /Component: Disclosure Group ===== #}